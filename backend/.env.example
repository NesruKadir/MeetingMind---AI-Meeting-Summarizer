# Copy this file to .env and fill in your keys

# OpenAI — for Whisper transcription
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — for Claude summarization
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid — for personalized email digests
# Get yours at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....
FROM_EMAIL=summaries@yourdomain.com

# Comma-separated list of allowed frontend origins (add your Vercel URL here after deploy)
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL connection string
# Local: postgresql://postgres:yourpassword@localhost/meeting_summarizer
# Railway: paste the connection string from your Railway dashboard
DATABASE_URL=postgresql://user:password@localhost/meeting_summarizer
